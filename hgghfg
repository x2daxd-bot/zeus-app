<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZEUS EMPIRE 🔱</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;700;900&display=swap');
        body { font-family: 'Cairo', sans-serif; background-color: #0b0f14; color: white; scroll-behavior: smooth; overflow-x: hidden; }
        
        .egy-nav { background-color: #0d1117; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .egy-card { position: relative; border-radius: 8px; overflow: hidden; background-color: #1a1d23; transition: 0.3s ease; aspect-ratio: 2/3; }
        .egy-card:hover { transform: scale(1.05); z-index: 10; border: 1px solid #eab308; }
        
        /* 🔱 تعديل النمط ليكون 3 بجانب بعضهم في الجوال 💀 */
        .main-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
        @media (min-width: 768px) { .main-grid { grid-template-columns: repeat(6, 1fr); gap: 15px; } }

        .card-tag { position: absolute; top: 5px; left: 5px; font-size: 8px; font-weight: 900; color: white; padding: 2px 5px; border-radius: 3px; z-index: 5; }
        .bottom-nav { position: fixed; bottom: 0; left: 0; width: 100%; background: #0d1117; border-top: 1px solid rgba(255,255,255,0.1); z-index: 100; height: 65px; display: flex; justify-content: space-around; align-items: center; }
        .bottom-nav button { color: #888; font-size: 10px; font-weight: 700; transition: 0.3s; }
        .bottom-nav button.active { color: #eab308; }
        
        #playerOverlay { position: fixed; inset: 0; background: black; z-index: 1000; display: none; flex-direction: column; }
        .hero-section { height: 50vh; background-size: cover; background-position: center; position: relative; display: flex; align-items: flex-end; padding: 20px; }
        .hero-overlay { position: absolute; inset: 0; background: linear-gradient(0deg, #0b0f14 0%, transparent 100%); }
    </style>
</head>
<body class="pb-24">

    <header class="fixed top-0 w-full z-[100] egy-nav px-5 py-4 flex justify-between items-center">
        <div class="flex items-center gap-3">
            <i class="fa-solid fa-bars text-gray-400 text-xl"></i>
            <div class="text-xl font-black italic tracking-tighter gold-glow">ZEUS <span class="text-yellow-500">EMPIRE</span></div>
        </div>
        <div class="flex items-center gap-4 text-gray-400">
            <button onclick="alert('فتح الإعدادات...')" class="hover:text-yellow-500"><i class="fa-solid fa-gear"></i></button>
            <button onclick="toggleSearch()" class="hover:text-yellow-500"><i class="fa-solid fa-magnifying-glass"></i></button>
        </div>
    </header>

    <section id="hero" class="hero-section mt-14" style="background-image: url('https://image.tmdb.org/t/p/original/6Mk9mS8u5v0r4jO7d08lD2WcE0m.jpg');">
        <div class="hero-overlay"></div>
        <div class="relative z-10 w-full text-center">
            <h1 id="heroTitle" class="text-3xl font-black mb-2 italic">تحميل...</h1>
            <button onclick="alert('بدء المشاهدة فوراً!')" class="bg-yellow-500 text-black px-6 py-2 rounded-full font-black text-sm">شاهد الآن</button>
        </div>
    </section>

    <div id="searchBar" class="hidden px-5 py-3 mt-2">
        <input type="text" id="searchInput" placeholder="ابحث عن فيلم أو أنمي..." class="w-full bg-zinc-800 border border-yellow-500/30 rounded-lg p-3 outline-none">
    </div>

    <main class="px-3 mt-6 space-y-10">
        
        <section>
            <h2 class="text-sm font-black mb-4 text-yellow-500 border-r-4 border-red-600 pr-2">أحدث الأفلام</h2>
            <div id="moviesGrid" class="main-grid"></div>
        </section>

        <section>
            <h2 class="text-sm font-black mb-4 text-yellow-500 border-r-4 border-red-600 pr-2">الأنمي الأكثر مشاهدة</h2>
            <div id="animeGrid" class="main-grid"></div>
        </section>

    </main>

    <div id="playerOverlay">
        <div class="p-4 flex justify-between items-center bg-zinc-900">
            <span id="playingTitle" class="font-black text-sm text-yellow-500"></span>
            <button onclick="closePlayer()" class="text-2xl">&times;</button>
        </div>
        <iframe id="videoIframe" class="w-full flex-1" src="" frameborder="0" allowfullscreen></iframe>
    </div>

    <nav class="bottom-nav">
        <button class="active" onclick="location.reload()"><i class="fa-solid fa-house text-xl"></i><br>الرئيسية</button>
        <button onclick="toggleSearch()"><i class="fa-solid fa-magnifying-glass text-xl"></i><br>البحث</button>
        <button onclick="alert('المكتبة قريباً')"><i class="fa-solid fa-layer-group text-xl"></i><br>المكتبة</button>
        <button onclick="alert('الإعدادات')"><i class="fa-solid fa-gear text-xl"></i><br>الإعدادات</button>
    </nav>

    <script>
        const API_KEY = 'a2c046dda79b56dc48db2aba391ec7be';

        async function initZeus() {
            // جلب الأفلام
            const mRes = await fetch(`https://api.themoviedb.org/3/movie/popular?api_key=${API_KEY}&language=ar`);
            const mData = await mRes.json();
            render(mData.results, 'moviesGrid', 'movie');

            // جلب الأنمي
            const aRes = await fetch(`https://api.themoviedb.org/3/discover/tv?api_key=${API_KEY}&with_genres=16&language=ar`);
            const aData = await aRes.json();
            render(aData.results, 'animeGrid', 'tv');

            // تحديث الهيرو
            const hero = mData.results[0];
            document.getElementById('hero').style.backgroundImage = `url('https://image.tmdb.org/t/p/original${hero.backdrop_path}')`;
            document.getElementById('heroTitle').innerText = hero.title;
        }

        function render(items, gridId, type) {
            const grid = document.getElementById(gridId);
            grid.innerHTML = items.slice(0, 12).map(item => `
                <div class="egy-card group" onclick="play('${item.id}', '${item.title || item.name}', '${type}')">
                    <img src="https://image.tmdb.org/t/p/w500${item.poster_path}" class="w-full h-full object-cover">
                    <span class="card-tag ${type === 'movie' ? 'bg-green-600' : 'bg-blue-600'}">${type === 'movie' ? 'فيلم' : 'حلقة'}</span>
                    <div class="absolute inset-x-0 bottom-0 p-2 bg-black/80">
                        <p class="text-[9px] font-bold truncate text-center">${item.title || item.name}</p>
                    </div>
                </div>
            `).join('');
        }

        function play(id, title, type) {
            const overlay = document.getElementById('playerOverlay');
            const iframe = document.getElementById('videoIframe');
            document.getElementById('playingTitle').innerText = title;
            overlay.style.display = 'flex';
            iframe.src = `https://vidsrc.me/embed/${type}?tmdb=${id}`;
        }

        function closePlayer() {
            document.getElementById('playerOverlay').style.display = 'none';
            document.getElementById('videoIframe').src = '';
        }

        function toggleSearch() {
            const bar = document.getElementById('searchBar');
            bar.classList.toggle('hidden');
            document.getElementById('searchInput').focus();
        }

        initZeus();
    </script>
</body>
</html>

